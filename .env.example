# Airacle 项目 API Keys 模板
# 复制到 projects/<name>/.env 并填入实际值
# ⚠️  .env 本身已在 .gitignore，绝对不要提交实际 key

# Anthropic / Claude Code（可选，也可在容器里走浏览器登录）
ANTHROPIC_API_KEY=

# OpenAI / Codex
OPENAI_API_KEY=

# GitHub PAT（用于 gh CLI、git push、GitHub API）
# 在 https://github.com/settings/tokens 创建
GITHUB_TOKEN=
GH_TOKEN=

# Cloudflare API Token
# 在 https://dash.cloudflare.com/profile/api-tokens 创建
CF_API_TOKEN=
CLOUDFLARE_API_TOKEN=
