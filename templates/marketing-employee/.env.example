# Marketing employee appliance local env
# Copy to appliance.env inside /srv/airacle/appliances/<name>/ and fill locally.
# Do not commit real secrets.

AIRACLE_APPLIANCE_NAME=example-marketing
AIRACLE_CUSTOMER_NAME=Example Customer
AIRACLE_EMPLOYEE_ROLE=marketing-employee
AIRACLE_DOMAIN=
TZ=America/Los_Angeles

# Core service images. Pin these to stable/date tags for production customers.
AIRACLE_AGENT_IMAGE=airacle-dev:latest
AIRACLE_OPENCLAW_IMAGE=

# Optional API keys for project code. Claude Code and Codex should use login flows
# whenever possible, with login state persisted under identity/.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# GitHub / Cloudflare operations
GITHUB_TOKEN=
GH_TOKEN=
CF_API_TOKEN=
CLOUDFLARE_API_TOKEN=

# Optional OpenClaw/OpenCloud/tool-specific settings
OPENCLAW_PORT=18890
OPENCLAW_BASE_URL=

# Optional Docker-in-Docker profile
# Enable only when running: docker compose --profile dind up -d
# DOCKER_HOST=tcp://dind:2375
